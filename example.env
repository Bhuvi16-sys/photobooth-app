# Azure Face API configurations
FACE_API_ENDPOINT="https://your-face-api-endpoint.cognitiveservices.azure.com/face/v1.0"
FACE_API_KEY="your_face_api_key_here"

# Azure Blob Storage connection (for temporary image caching during analysis)
BLOB_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your_storage_account;AccountKey=your_account_key;EndpointSuffix=core.windows.net"
